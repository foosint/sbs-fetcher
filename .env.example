# sbs-fetcher configuration
# Copy this to .env and fill in your values.
# .env is gitignored and never committed.

# ─── Database ────────────────────────────────────────────────────────────────
SBS_DB_PATH=./sbs.db

# ─── GitHub ───────────────────────────────────────────────────────────────────
# Personal access token with repo write access.
# Create at: GitHub → Settings → Developer settings → Personal access tokens → Fine-grained
# Required permission: Contents (read & write) on the sbs-stats repo.
GITHUB_TOKEN=github_pat_XXXXXXXXXXXXXXXXXXXX

# Target repo in "owner/repo" format.
GITHUB_REPO=YOUR_USERNAME/sbs-stats

# Branch to push to.
GITHUB_BRANCH=main

# Path of the DB file inside the repo.
GITHUB_DB_PATH=data/sbs.db

# ─── Git commit identity ──────────────────────────────────────────────────────
GIT_USER_NAME=Your Name
GIT_USER_EMAIL=you@example.com

# ─── SSH commit signing (optional) ───────────────────────────────────────────
# Leave GIT_SIGN_KEY empty to disable signing.
#
# Set to the path of your SSH private key — same key you use in your git config:
#   [user] signingkey = ...
#   [gpg]  format = ssh
#   [commit] gpgsign = true
#
# The public key must be added to GitHub as a *signing key* (not just an auth key):
#   GitHub → Settings → SSH and GPG keys → New SSH key → Key type: Signing Key
GIT_SIGN_KEY=/home/pi/.ssh/keyfile
